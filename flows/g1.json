    {
        "id": "5187f40ccfebca82",
        "type": "function",
        "z": "85619254656ffc76",
        "name": "Relé 1 GPIO24 — Activo mientras suene la alarma",
        "func": "let payload = msg.payload;\nif (typeof payload === 'string') {\n    try { payload = JSON.parse(payload); } catch(e) {}\n}\nconst active = (payload !== null && typeof payload === 'object')\n    ? !!payload.active\n    : (payload === 1 || payload === true);\nnode.send({ payload: active ? 1 : 0 });\nreturn null;",
        "outputs": 1,
        "noerr": 0,
