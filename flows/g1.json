    {
        "id": "a5780aaed48494f0",
        "type": "function",
        "z": "85619254656ffc76",
        "name": "Pulso 500ms → Relé 1 GPIO24 (todos los cercos)",
        "func": "let payload = msg.payload;\nif (typeof payload === 'string') {\n    try { payload = JSON.parse(payload); } catch(e) {}\n}\nconst active = (payload !== null && typeof payload === 'object')\n    ? !!payload.active\n    : (payload === 1 || payload === true);\nif (!active) return null;\nnode.send({ payload: 1 });\nsetTimeout(() => node.send({ payload: 0 }), 500);\nreturn null;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 440,
        "y": 120,
        "wires": [
            [
                "bf99d9020a3e2288",
                "7bb8fa0d2afc0ed3"
            ]
        ]
    },
